# Copy this file to .env and fill in real values before deploying.
# `docker compose up` reads apps/api/.env for the api, worker, and migrate
# services — never commit a real .env file.

APP_NAME=helios-api
ENVIRONMENT=production

# In Docker Compose, "postgres"/"redis" are the service hostnames, not
# localhost — see infra/docker-compose.yml, which overrides these two for
# you. Only edit these here if you're running the API outside Docker.
DATABASE_URL=postgresql+asyncpg://helios:helios@postgres:5432/helios
REDIS_URL=redis://redis:6379/0

# Generate a real secret before deploying anywhere reachable, e.g.:
#   python -c "import secrets; print(secrets.token_urlsafe(32))"
# Every JWT issued with a leaked/default secret can be forged.
JWT_SECRET=change-me-in-production
JWT_ALGORITHM=HS256
JWT_ACCESS_TOKEN_EXPIRE_MINUTES=30
